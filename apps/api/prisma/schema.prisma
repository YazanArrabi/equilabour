generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  worker
  company
}

enum ApplicationStatus {
  pending
  accepted
  rejected
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship
  freelance
}

enum ExperienceLevel {
  entry
  junior
  mid
  senior
}

enum JobStatus {
  active
  closed
  deleted
}

enum FileAssetType {
  cv
  certificate
  recommendation_letter
  profile_picture
  logo
}

enum FileOwnerType {
  worker
  company
}

enum AIAnalysisStatus {
  fresh
  stale
  failed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole

  workerProfile  WorkerProfile?
  companyProfile CompanyProfile?
  refreshTokens  RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model WorkerProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  fullName    String
  phoneNumber String?
  location    String?

  profilePictureFileId String? @unique

  skills                String[]
  yearsOfExperience     Int      @default(0)
  workExperienceSummary String?
  pastJobTitles         String[]
  employmentHistory     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  profilePictureFile FileAsset?         @relation("WorkerProfilePicture", fields: [profilePictureFileId], references: [id], onDelete: SetNull)
  files              FileAsset[]        @relation("WorkerFiles")
  applications       JobApplication[]
  aiAnalysisResults  AIAnalysisResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([location])
}

model CompanyProfile {
  id     String @id @default(cuid())
  userId String @unique

  companyName String
  location    String?
  industry    String?
  contactInfo String?
  overview    String?

  logoFileId String? @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  logoFile FileAsset?  @relation("CompanyLogo", fields: [logoFileId], references: [id], onDelete: SetNull)
  files    FileAsset[] @relation("CompanyFiles")

  jobPostings JobPosting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyName])
  @@index([location])
  @@index([industry])
}

model JobPosting {
  id               String @id @default(cuid())
  companyProfileId String

  title          String
  description    String
  requiredSkills String[]

  experienceLevel ExperienceLevel
  employmentType  EmploymentType

  salary   String?
  location String?

  payMin Int?
  payMax Int?

  status JobStatus @default(active)

  postedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile CompanyProfile   @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  applications   JobApplication[]

  @@index([companyProfileId])
  @@index([status])
  @@index([postedAt(sort: Desc)])
  @@index([location])
  @@index([employmentType])
  @@index([experienceLevel])
  @@index([payMin])
  @@index([payMax])
}

model JobApplication {
  id              String @id @default(cuid())
  jobPostingId    String
  workerProfileId String

  message String?
  status  ApplicationStatus @default(pending)

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPosting    JobPosting    @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@unique([jobPostingId, workerProfileId])
  @@index([workerProfileId])
  @@index([jobPostingId])
  @@index([status])
}

model FileAsset {
  id String @id @default(cuid())

  ownerType FileOwnerType

  workerProfileId  String?
  companyProfileId String?

  type FileAssetType

  originalFilename String
  mimeType         String
  sizeBytes        Int

  s3Key String @unique

  isCompanyIssued Boolean @default(false)

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workerProfile  WorkerProfile?  @relation("WorkerFiles", fields: [workerProfileId], references: [id], onDelete: Cascade)
  companyProfile CompanyProfile? @relation("CompanyFiles", fields: [companyProfileId], references: [id], onDelete: Cascade)

  workerProfilePicture WorkerProfile?  @relation("WorkerProfilePicture")
  companyLogo          CompanyProfile? @relation("CompanyLogo")

  @@index([workerProfileId])
  @@index([companyProfileId])
  @@index([type])
  @@index([ownerType])
}

model AIAnalysisResult {
  id              String @id @default(cuid())
  workerProfileId String

  status AIAnalysisStatus @default(fresh)

  skillSummary String
  skillRating  Int
  topSkills    String[]

  matchRecommendations     Json
  candidateRecommendations Json

  lastAnalyzedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@index([workerProfileId])
  @@index([status])
  @@index([lastAnalyzedAt(sort: Desc)])
}

model RefreshToken {
  id     String @id @default(cuid())
  userId String

  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
